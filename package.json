{
  "name": "clawpowers-agent",
  "version": "1.1.7",
  "description": "Autonomous AI coding agent that orchestrates 26+ skills via OpenClaw \u2014 thin runtime over the clawpowers capability library",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clawpowers": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests demos",
    "sync:skills": "node scripts/sync-skills.mjs",
    "smoke:openclaw": "node scripts/ci-smoke-openclaw.mjs",
    "verify:pack": "npm pack --dry-run",
    "clean": "rm -rf dist",
    "demo:task": "tsx demos/demo-task-execution.ts",
    "demo:memory": "tsx demos/demo-memory-cycle.ts",
    "demo:rsi": "tsx demos/demo-rsi-cycle.ts",
    "prepack": "npm run sync:skills && npm run build"
  },
  "files": [
    "dist/",
    "skills/",
    "profiles/",
    "index.ts",
    "openclaw.plugin.json",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "COMPATIBILITY.md",
    "KNOWN_LIMITATIONS.md",
    "LICENSING.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agent",
    "coding",
    "openclaw",
    "rsi",
    "autonomous",
    "self-improvement",
    "x402",
    "payments",
    "memory",
    "clawpowers"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/up2itnow0822/ClawPowers-Agent.git"
  },
  "author": "Bill Wilson <bill@ai-agent-economy.com>",
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "clawpowers": "^2.2.6",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "clawpowers": "^2.2.6",
    "openclaw": "2026.4.21"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "clawpowers": "^2.2.6",
    "eslint": "^9.24.0",
    "globals": "^17.5.0",
    "openclaw": "2026.4.21",
    "tsup": "^8.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
  },
  "homepage": "https://clawpowers.ai/agent",
  "bugs": {
    "url": "https://github.com/up2itnow0822/ClawPowers-Agent/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin": {
      "import": "./dist/openclaw-plugin.js",
      "types": "./dist/openclaw-plugin.d.ts"
    }
  }
}
